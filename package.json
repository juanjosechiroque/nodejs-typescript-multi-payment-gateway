{
    "name": "nodejs-typescript-multi-payment-gateway",
    "version": "1.0.0",
    "description": "TypeScript REST API with multi-provider payment gateway integration using the adapter pattern",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "start": "NODE_ENV=production node dist/index.js",
        "dev": "nodemon",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "validate": "eslint . && prettier --check .",
        "format": "prettier --write . && eslint . --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "payments",
        "stripe",
        "payment-gateway",
        "adapter-pattern",
        "express",
        "nodejs",
        "typescript"
    ],
    "author": "juanjosechiroque",
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "dependencies": {
        "cors": "2.8.6",
        "express": "5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "8.2.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "stripe": "^22.3.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.0",
        "@types/supertest": "^7.2.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "nodemon": "3.1.14",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.9.4",
        "supertest": "^7.2.2",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vitest": "^4.1.10"
    }
}
